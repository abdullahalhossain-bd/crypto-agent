# =============================================================================
# TRADING SYSTEM ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit the real .env file to version control.
# Add .env to your .gitignore if not already present.
# =============================================================================

# -----------------------------------------------------------------------------
# METATRADER 5 CREDENTIALS (REQUIRED FOR LIVE MODE)
# -----------------------------------------------------------------------------
# SECURITY GUIDANCE:
# - Use a strong, unique password (16+ characters recommended)
# - Never use the same password across multiple brokers
# - Rotate passwords periodically (every 90 days minimum)
# - Store backup credentials in a secure password manager
# - Consider using a dedicated trading account with limited capital
#
# Example: MT5_PASSWORD="Str0ng!P@ssw0rd#2024$Trading"

MT5_PASSWORD=

# -----------------------------------------------------------------------------
# OPTIONAL: API KEYS FOR EXTERNAL SERVICES
# -----------------------------------------------------------------------------
# Uncomment and set these if using LLM/AI features or external data providers

# OpenAI API Key (for LLM signal enhancement)
# OPENAI_API_KEY="sk-..."

# Anthropic API Key (alternative LLM provider)
# ANTHROPIC_API_KEY="sk-ant-..."

# News API Key (for economic calendar integration)
# NEWS_API_KEY="..."

# -----------------------------------------------------------------------------
# RUNTIME CONFIGURATION OVERRIDES
# -----------------------------------------------------------------------------
# These override settings in config/config.yaml

# Execution mode override: simulation | paper | live
# EXECUTION_MODE="paper"

# Paper trading delay fraction (0.1 = 10% of live delay)
# PAPER_DELAY_FRACTION="0.1"

# Log level override: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL="INFO"

# Dashboard port override
# DASHBOARD_PORT="8050"

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (if using external database)
# -----------------------------------------------------------------------------
# DATABASE_URL="postgresql://user:password@localhost:5432/trading_bot"
# REDIS_URL="redis://localhost:6379/0"
